-- Roblox Alt Account Detection and Kick Script
-- This script detects alt accounts and kicks the user from the game

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")

-- Configuration
local CONFIG = {
    CHECK_IP = true,
    CHECK_USERID = true,
    CHECK_ACCOUNT_AGE = true,
    CHECK_PREMIUM = true,

    MIN_ACCOUNT_AGE = 30,

    KICK_MESSAGE = "Alt account detected. This script is restricted to main accounts only.",
    DETECTION_DELAY = 2,

    WHITELIST = {
        "xyrie_achie","RichMoney3221","1ROB1OXIAN"
    }
}

-- UI Elements
local function createDetectionUI()
    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")

    local screen = Instance.new("ScreenGui")
    screen.Name = "AltDetectionScreen"
    screen.ResetOnSpawn = false
    screen.IgnoreGuiInset = true
    screen.ZIndexBehavior = Enum.ZIndexBehavior.Global
    screen.DisplayOrder = 999999
    screen.Parent = playerGui

    local bg = Instance.new("Frame", screen)
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bg.BackgroundTransparency = 0.8
    bg.BorderSizePixel = 0

    local container = Instance.new("Frame", screen)
    container.AnchorPoint = Vector2.new(0.5, 0.5)
    container.Position = UDim2.new(0.5, 0, 0.5, 0)
    container.Size = UDim2.new(0, 400, 0, 250)
    container.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    container.BorderSizePixel = 0

    local corner = Instance.new("UICorner", container)
    corner.CornerRadius = UDim.new(0, 16)

    local title = Instance.new("TextLabel", container)
    title.Size = UDim2.new(1, 0, 0, 40)
    title.Position = UDim2.new(0, 0, 0, 10)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBold
    title.TextSize = 20
    title.TextColor3 = Color3.fromRGB(180, 0, 255)
    title.Text = "SECURITY CHECK"
    title.TextXAlignment = Enum.TextXAlignment.Center

    local status = Instance.new("TextLabel", container)
    status.Size = UDim2.new(1, -40, 0, 60)
    status.Position = UDim2.new(0, 20, 0, 130)
    status.BackgroundTransparency = 1
    status.Font = Enum.Font.Gotham
    status.TextSize = 16
    status.TextColor3 = Color3.fromRGB(200, 200, 200)
    status.Text = "Verifying account authenticity..."
    status.TextWrapped = true

    local progressBarBg = Instance.new("Frame", container)
    progressBarBg.Size = UDim2.new(1, -40, 0, 6)
    progressBarBg.Position = UDim2.new(0, 20, 0, 200)
    progressBarBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

    local progressBarFill = Instance.new("Frame", progressBarBg)
    progressBarFill.Size = UDim2.new(0, 0, 1, 0)
    progressBarFill.BackgroundColor3 = Color3.fromRGB(180, 0, 255)

    return screen, status, progressBarFill
end

local Detection = {}

function Detection.isWhitelisted(username)
    for _, v in ipairs(CONFIG.WHITELIST) do
        if username == v then
            return true
        end
    end
    return false
end

function Detection.checkAccountAge(userId)
    local success = pcall(function()
        game:GetService("Players"):GetUserThumbnailAsync(
            userId,
            Enum.ThumbnailType.HeadShot,
            Enum.ThumbnailSize.Size420x420
        )
    end)

    if not success then
        return false, "Unable to verify account"
    end

    return true, "Account age verified"
end

function Detection.checkPremiumStatus()
    local player = Players.LocalPlayer
    if not player then
        return false, "Player not found"
    end

    if player.MembershipType ~= Enum.MembershipType.Premium then
        return false, "Premium membership required"
    end

    return true, "Premium status verified"
end

local function main()
    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")

    local screen, statusText, progressBar = createDetectionUI()

    local startTime = tick()
    local totalDuration = CONFIG.DETECTION_DELAY

    task.spawn(function()
        while tick() - startTime < totalDuration do
            local progress = (tick() - startTime) / totalDuration
            progressBar:TweenSize(
                UDim2.new(progress, 0, 1, 0),
                Enum.EasingDirection.Out,
                Enum.EasingStyle.Linear,
                0.1
            )
            task.wait(0.05)
        end
    end)

    task.wait(CONFIG.DETECTION_DELAY)

    if Detection.isWhitelisted(player.Name) then
        statusText.Text = "Account verified"
        task.wait(2)
        screen:Destroy()

        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/jazzedd/JazradScript/refs/heads/main/Script"))()
        end)

        return
    end

    statusText.Text = "ALT ACCOUNT DETECTED"
    task.wait(1)

    statusText.Text = "Please use a main account"
    task.wait(1)

    statusText.Text = "https://discord.gg/72tfGCun2C"

    if setclipboard then
        setclipboard("https://discord.gg/MSwQjUJSU4")
    end

    screen:Destroy()

    game.Players.LocalPlayer:Kick(
        "The script has been discontinued. My Discord server should be copied to your clipboard. I don't have plans to continue it, but may in the future. I will be working on my Skyblock scripts, so go check them out on my website."
    )
end

pcall(function()
    main()
end)
