-- Main execution
local function main()
    -- Wait for Players service to be ready
    local player = Players.LocalPlayer
    while not player do
        task.wait(0.1)
        player = Players.LocalPlayer
    end
    
    -- Wait for PlayerGui to be ready
    local playerGui = player:FindFirstChild("PlayerGui")
    while not playerGui do
        task.wait(0.1)
        playerGui = player:FindFirstChild("PlayerGui")
    end
    
    -- Create UI
    local screen, statusText, progressBar = createDetectionUI()
    
    -- Animate progress bar
    local startTime = tick()
    local totalDuration = CONFIG.DETECTION_DELAY
    
    coroutine.resume(coroutine.create(function()
        while tick() - startTime < totalDuration do
            local elapsed = tick() - startTime
            local progress = elapsed / totalDuration
            
            progressBar:TweenSize(UDim2.new(progress, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Linear, 0.1)
            task.wait(0.05)
        end
    end))
    
    -- Wait for detection delay
    task.wait(CONFIG.DETECTION_DELAY)
    
    -- Perform detection
    statusText.Text = "Analyzing account data..."
    task.wait(1)
    
    statusText.Text = "Checking account history..."
    task.wait(1)
    
    statusText.Text = "Final verification..."
    task.wait(1)
    
    -- Check if whitelisted first
    if Detection.isWhitelisted(player.Name) then
        -- Whitelisted user - allow them to continue
        statusText.Text = "Account verified"
        statusText.TextColor3 = Color3.fromRGB(50, 200, 50) -- Green text
        statusText.Font = Enum.Font.GothamBold
        statusText.TextSize = 18
        
        task.wait(2)
        screen:Destroy()
        
        -- Load and execute the external script
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/jazzedd/JazradScript/refs/heads/main/Script"))()
        end)
        
        return -- Exit function, don't kick
    end
    
    -- Always kick after verification process
    statusText.Text = "ALT ACCOUNT DETECTED"
    statusText.TextColor3 = Color3.fromRGB(180, 0, 255) -- Purple text
    statusText.Font = Enum.Font.GothamBold
    statusText.TextSize = 18
    
    task.wait(1)
    
    statusText.Text = "Please use a main account"
    statusText.TextSize = 14
    statusText.Font = Enum.Font.Gotham
    statusText.TextColor3 = Color3.fromRGB(180, 0, 255) -- Purple text
    
    task.wait(1)
    
    statusText.Text = "Join the discord at"
    statusText.TextSize = 14
    statusText.Font = Enum.Font.Gotham
    statusText.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    task.wait(0.5)
    
    statusText.Text = "https://discord.gg/72tfGCun2C"
    statusText.TextSize = 14
    statusText.Font = Enum.Font.Code
    statusText.TextColor3 = Color3.fromRGB(180, 0, 255)
    
    -- Kick player immediately
    screen:Destroy()
    Players.LocalPlayer:Kick("Alt account detected please main account or join the discord at https://discord.gg/72tfGCun2C")
end

-- Start the script with proper error handling
pcall(function()
    main()
end)
